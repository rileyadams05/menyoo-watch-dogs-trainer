{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MENYOO",
  "version": "0.1.0",
  "identifier": "com.menyoo.watchdogstrainer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MENYOO Watch Dogs Trainer",
        "width": 1000,
        "height": 620,
        "resizable": true,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/Icon.ico", "icons/icon.png", "icons/32x32.png", "icons/128x128.png"
    ]
  }
}
