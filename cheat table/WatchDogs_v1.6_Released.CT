          <ID>88711</ID>
          <Description>"Teleport &amp; Coordinates..."</Description>
          <Options moHideChildren="1" moManualExpandCollapse="1" moDeactivateChildrenAsWell="1"/>
          <LastState/>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>{ Game   : Watch_Dogs.exe
  Version: 
  Date   : 2023-01-09
  Author : Paul44

  Gets coordinates player...
}

[ENABLE]
{$lua}

local startAddr = getAddress('Disrupt_b64.dll')
local endAddr = startAddr + getModuleSize('Disrupt_b64.dll')
-- +E0 +88 +280 +0 +80 +18 .. +10
  getStaticAddr("4C 8B F0 48 89 45 67",4,"pMapWaypt",0,startAddr,endAddr)


{$asm}

aobscanmodule(Coord,Disrupt_b64.dll,0F 5C 00 0F 29 45 B0)
registersymbol(Coord)
alloc(newmem,$100,Coord)

aobscanmodule(YawPitch,Disrupt_b64.dll,54 89 87 88 00 00 00)
registersymbol(YawPitch)
alloc(newmem2,$100,YawPitch)

aobscanmodule(CoordWrite,Disrupt_b64.dll,0F 29 80 20 01 00 00 48 8B 8D)
registersymbol(CoordWrite)
alloc(newmem3,$100,CoordWrite)

globalalloc(pCoord,8,Coord)
globalalloc(pYawPitch,8,Coord)


// 'Player Coordinates' script
// x64 pointers are 8-bytes long
globalalloc(pStructCrdBase,8,$process)
globalalloc(pStructCrdOffset,4,$process)
globalalloc(pCamera,8,$process)

// save current location x,y,z coordinates (float)...
globalalloc(OrigCoord,12,Coord)
// init script variables
globalalloc(XYstepVal,4,Coord)
globalalloc(ZstepVal,4,Coord)
globalalloc(ZstepdropHeight,4,Coord)
globalalloc(nDropHeight,4,Coord)

globalalloc(Xval,4,Coord)
globalalloc(Yval,4,Coord)
globalalloc(Zval,4,Coord)
globalalloc(bFreeRoam,1,Coord)
globalalloc(bCoordSave,1,Coord)
globalalloc(bCoordRestore,1,Coord)
globalalloc(nFrameSpeed,4,Coord)

nDropHeight:
dd (float)3

XYstepVal:
dd (float)1

ZstepVal:
dd (float)1

ZstepdropHeight:
dd (float)1

bFreeRoam:
db 0

// save_restore coordinates...
bCoordSave:
db 0
bCoordRestore:
db 0

// freeroam timer interval (smoother/faster = 50 - smoothest/fast = 20)
// choose between player or camera
nFrameSpeed:
dd (int)50

// fill in offset here ~ see table coordinates...
pStructCrdOffset:
dd 120

// coordinates...
label(code)
label(return)

newmem:
  push r15
  mov r15,pCoord
  mov [r15],rax
  pop r15
code:
  subps xmm0,[rax]
  movaps [rbp-50],xmm0
  jmp return

Coord:
  jmp newmem
  nop 2
return:

// yaw-pitch...
label(code2)
label(return2)

newmem2:
  push r15
  mov r15,pYawPitch
  mov [r15],rdi
  pop r15
code2:
  mov [rdi+00000088],eax
  jmp return2

YawPitch+01:
  jmp newmem2
  nop
return2:

// write coordinates - freeroam...
label(code3)
label(return3)

// subroutines...
alloc(updateCrd,$100,$process)

updateCrd:
  // updated coordinates...
  push r15
  mov r15,pStructCrdBase
  mov rbx,[r15]
  mov r15,pStructCrdOffset
  add rbx,[r15]
  mov r15,Xval
  mov edx,dword ptr [r15]
  mov [rbx],edx
  add rbx,4
  mov r15,Yval
  mov edx,dword ptr [r15]
  mov [rbx],edx
  add rbx,4
  mov r15,Zval
  mov edx,dword ptr [r15]
  mov [rbx],edx
  pop r15
  ret

// Player roaming...
newmem3:
  push rbx
  push rdx
  push r15
  mov r15,pCoord
  mov rbx,[r15]
  sub rbx,0x120
  cmp rbx,rax
  jne code3
  // freecam routines... x64: 8-byte ptrs &amp; r?x registers...
  mov r15,bFreeRoam
  cmp byte ptr [r15],1
  jne code3
  mov r15,pCoord
  mov rbx,[r15]
  mov r15,pStructCrdBase
  mov [r15],rbx
  // updated coordinates...
  mov r15,updateCrd
  call r15
  mov r15,pStructCrdBase
  mov rbx,[r15]
  movaps xmm0,[rbx+120]

code3:
  pop r15
  pop rdx
  pop rbx
@@:
  movaps [rax+00000120],xmm0
  jmp return3

CoordWrite:
  jmp newmem3
  nop 2
return3:


[DISABLE]

Coord:
  db 0F 5C 00 0F 29 45 B0

unregistersymbol(Coord)
dealloc(newmem)

YawPitch+01:
  db 89 87 88 00 00 00

unregistersymbol(YawPitch)
dealloc(newmem2)

CoordWrite:
  db 0F 29 80 20 01 00 00

unregistersymbol(CoordWrite)
dealloc(newmem3)

