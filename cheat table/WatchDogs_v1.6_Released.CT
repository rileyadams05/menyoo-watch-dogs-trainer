  if not pcall(function() getCarStruct() end) then return end

-- see Time Of Day...
function displayIimeHr()
    local al = getAddressList()
    local mr = al.getMemoryRecordByID(88805)        -- Time Of Day...
    if not mr.Active then return end

    mr = al.getMemoryRecordByID(88800)              -- Time (in secs)
    local curVal = tonumber(mr.Value)
    mr = al.getMemoryRecordByID(90491)              -- Time (in hrs)
    mr.Value = string.format("%.2f", curVal/3600)
end

displayIimeHr()

