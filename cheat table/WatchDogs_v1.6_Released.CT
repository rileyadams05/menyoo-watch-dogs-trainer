          <CheatEntries>
            <CheatEntry>
              <ID>267</ID>
              <Description>"Teleport to Waypoint..."</Description>
              <Options moManualExpandCollapse="1"/>
              <LastState/>
              <Color>FF00FF</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>{ Game   : ImmortalsFenyxRising.exe
  Version:
  Date   : 2018-05-17
  Author : Paul44

  Teleports player to Map Waypoint Marker...
}

[ENABLE]


{$lua}

local addrWaypoint = getAddress("[[[[[[pMapWaypt]]+0xE0]+0x88]+0x280]]")
local addrEntity = readPointer(getAddress("pCoord"))
local CrdOffset = 0x0                 -- readInteger(getAddress("pStructCrdOffset"))
addrEntity = addrEntity + CrdOffset

local bWaypoint = readBytes(addrWaypoint+0x44)
if (bWaypoint ~= 1) then return end
--print(string.format('&lt;['.. "%X" ..']&gt; ~ %X &lt;= %d',addrWaypoint,addrEntity,bWaypoint))

local coordX = readFloat(addrEntity)
local coordY = readFloat(addrEntity+0x4)
local coordZ = readFloat(addrEntity+0x8)
-- if error, restore original coordinates...
if not pcall(SetCoord) then
    --print('errors...')
    local addrC3 = getAddress("nCrash3")
    local nCount = readInteger(addrC3)
    nCount = nCount + 1
    writeInteger(addrC3, nCount)
    writeFloat(addrEntity,coordX)
    writeFloat(addrEntity+0x4,coordY)
    writeFloat(addrEntity+0x8,coordZ)
end

function SetCoord()
    -- Icon Coordinates also reside in Base structure: +50 .. +54 .. +58
    local IconHeight = 3.0
    local addrHeight = getAddress("nDropHeight")
    local fHeight = readFloat(addrHeight)

    local bTypeWaypt = readBytes(addrWaypoint+0x68)
    local addrGPS = readPointer(addrWaypoint+0x80)
    local xOffset = 0x20
    --print(string.format('[%d] - %X - %X',bTypeWaypt,addrGPS,xOffset))
    if (bTypeWaypt ~= 8 and readFloat(addrGPS+0x1C) ~= 0) then xOffset = 0x18 end
    local MapX = readFloat(addrGPS+xOffset)
    local MapY = readFloat(addrGPS+xOffset+0x4)
    local MapZ = readFloat(addrGPS+xOffset+0x8)
    --print(string.format('[%d] - %X: %5.3f  %5.3f  %5.3f - %X',bTypeWaypt,addrGPS,MapX,MapY,MapZ,xOffset))

    local bMapUpdate = true
    if bMapUpdate then
        --max: less chance of falling through surface - min: eliminates extreme high values...
        writeFloat(addrEntity+0x8,math.max(MapZ+IconHeight,MapZ+fHeight))
        writeFloat(addrEntity,MapX)
        writeFloat(addrEntity+0x4,MapY)
    end
end

    -- enable godmode...
  local al = getAddressList()
  local mr = al.getMemoryRecordByID(90432)
  mr.Active = true

  mr = al.getMemoryRecordByID(267)
  local timerMr = createTimer(getMainForm())
  timerMr.Interval = 100
  timerMr.OnTimer = function(timer)
      mr.Active = false
      timerMr.destroy()
  end

