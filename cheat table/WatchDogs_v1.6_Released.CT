function getCarStruct()
  local addrCarHealth = getAddressSafe('[[[[[[pChainCar]]+0x90]+0x8]+0x68]+0x8]')
  local addrCarHealth2 = getAddress('pCarHealth')
  if addrCarHealth == nil then addrCarHealth = 0 end
  writeQword(addrCarHealth2,addrCarHealth)
end

