            <CheatEntry>
              <ID>16976</ID>
              <Description>"Manage Progression Wheel..."</Description>
              <LastState/>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript Async="1">{ Game   : Watch_Dogs.exe
  Version:
  Date   : 2020-11-10
  Author : Paul44

  Manage Progression Wheel...
}

[ENABLE]

{$lua}
local f = nil
local nChoice = 0
local sMsg = ''
local sInfo = ''
local sListItems
addrStruct = ''
strStruct = ''


function setReward(sender)
  local sText = 'Do you want to set the Reward now...? \n' ..
                'Note: [All] = set ALL Rewards ! \n\n' ..
                '(make sure to have a save backup at hand)'
  local nResult = messageDialog(sText, mtInformation, mbYes, mbAll, mbCancel)
  if not (nResult == 6 or nResult == 8) then return end

  local nItems = f.ListBox.Items.Count
  local nCount = 0
  if (nResult == 6) then
      nCount = f.ListBox.ItemIndex
      if (nCount &lt; 0) then return end
      nItems = nCount+1
  end
  for i = nCount,nItems-1 do
      local sItem = f.ListBox.Items[i]
      local addrItem = sItem:match("{(.-)}")
      addrItem = tonumber(addrItem,16)
      local nCounter = readInteger(addrItem+0x24)
      -- get thresholds...
      local addrChallenge = readPointer(addrItem+0x08)
      local nChallenge = readInteger(addrChallenge+0x48)
      addrChallenge = readPointer(addrChallenge+0x40)
      local nRecLen = 0x20
      -- set reward_threshold list...
      local nCount = 1
      for j=0,nChallenge-1 do
          local addrChal = addrChallenge+j*nRecLen+0x8
          local nChall = readInteger(addrChal)
          if (nChall &gt; nCounter) then writeInteger(addrChal,nCounter + nCount); nCount = nCount +1 end
      end
  end
  getProgression()                               -- refresh list
end


function getProgression()
  local startAddr = getAddress('Disrupt_b64.dll')
  local endAddr = startAddr + getModuleSize('Disrupt_b64.dll')

  -- +10 +78 +98 .. +BC4
  getStaticAddr("33 FF 48 89 7D C7 48 89",4,"pChainProgr",0,startAddr,endAddr)

  --local addrProgr = getAddress('[[[[pChainProgr]+0x10]+0x78]+0x98]')
  local addrProgr = getAddress('[[[[pChainProgr]]+0x10]+0x78]+0x98')
  local nRecord = readInteger(addrProgr+0x8)
  local nRecordLen = 0x30
  --print(string.format('%X ~ %d',addrProgr,nRecord))

  local sMsg = 'List Progression Rewards'
  --if (nChoice == 2) then sMsg = 'List All Challenges' end

  -- see Form Recyclebin fn...
  execRoutine = setReward

       -- google: cheat engine Async exec Form invalid window handle
     synchronize(function()
         -- painting form...
         f = IconList
         f.Width = 850
         f.Height = 800
         f.Show()
         f.Caption = 'WD1 - Challenge Items...'
         local lBox = f.ListBox
         lBox.Clear()
         local lbTitle = f.IconTitle
         lbTitle.Caption = 'One moment please... processing...'
         local lbInfo = f.IconInfo
         lbInfo.Caption = ''
         local lbHead = f.IconHead
         lbHead.Caption = '  #         addrChall + Offset    |  Actual    Total     Challenge   #    Thresholds'
         local lbMsg = f.IconMessage
         lbMsg.Caption = "See Readme on how to manage \n and use this info..."
         --lbMsg.Visible = true
         local cbGod = f.GodMode
         f.GodMode.Caption  = 'God Mode:'
         -- hide info...
         f.pCoord.Visible = false
         f.Structure.Visible = true
         f.Structure.Hint = 'Edit reward...'
         f.RecycleBin.Visible = true
         --f.RecycleBin.Right = 25
         --f.RecycleBin.Anchors = 'akTop,akRight'
         --f.RecycleBin.BorderSpacing.Right = 20
         f.RecycleBin.Hint = 'Set reward threshold...'
         if (nChoice == 2) then
            f.Structure.Visible = false
            f.RecycleBin.Visible = false
         end

         lbTitle.Caption = sMsg
         lbInfo.Caption = string.format('Challenges: {%X + %d}',addrProgr,nRecord)
     end)

     aStructGui = {'Watch Dogs - Edit Reward','WD_Reward',400,200,false,200,200}
     aStructInfo = { {'Actual',0x24,vtDword,true} }

  local nCount = 0
  local nCount1 = 0
  for i=0,nRecord-1 do
      local addrItem = readPointer(addrProgr) + nRecordLen * i
      local nCounter = readInteger(addrItem+0x24)
      local nTotal = readInteger(addrItem+0x28)
      local addrChallenge = readPointer(addrItem+0x08)
      local nChallenge = readInteger(addrChallenge+0x48)
      addrChallenge = readPointer(addrChallenge+0x40)
      local nRecLen = 0x20
      -- build challenge_threshold list...
      local sChallenges = ''
      for j=0,nChallenge-1 do
          local nChall = readInteger(addrChallenge+j*nRecLen+0x8)
          if (j == 0) then sChallenges = nChall else sChallenges = sChallenges .. ' - ' .. nChall end
      end

      if (addrChallenge ~= 0) then
            local sName = string.format('[%03d]: {%10X} + %04X      |  %6d   %6d  | %10X  %2d =&gt; %s',
                               i+1,addrItem,nRecordLen * i,nCounter,nTotal,addrChallenge,nChallenge,sChallenges)

            f.ListBox.Items.Add(sName)
      end
  end
end

nChoice = readBytes(getAddress("bChoice"),1)
--if not (nChoice == 1 or nChoice == 2) then return end

getProgression()



{$asm}
test al,al


