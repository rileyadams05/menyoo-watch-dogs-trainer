          <AssemblerScript>{ Game   : Watch_Dogs.exe
  Version: 
  Date   : 2023-01-14
  Author : Paul44

  - Collects heat level...
  - Resets police radar...
}

[ENABLE]

aobscanmodule(HeatLevel,Disrupt_b64.dll,44 8B 46 0C 45 85 C0)
registersymbol(HeatLevel)
alloc(newmem,$100,HeatLevel)

aobscanmodule(PoliceRadar,Disrupt_b64.dll,F3 0F 58 47 50 F3)
registersymbol(PoliceRadar)
alloc(newmem2,$100,PoliceRadar)

globalalloc(pHeatLevel,8,HeatLevel)
globalalloc(pPoliceRadar,8,PoliceRadar)
globalalloc(bPoliceRadar,1,PoliceRadar)

bPoliceRadar:
db 0

// heatlevel...
label(code)
label(return)

newmem:
  push r15
  mov r15,pHeatLevel
  mov [r15],rsi
  pop r15
  //mov [rsi+0C],0
code:
  mov r8d,[rsi+0C]
  test r8d,r8d
  jmp return

HeatLevel:
  jmp newmem
  nop 2
return:

// police radar...
// flag: +54 = 1 (no radar)
label(code2)
label(return2)

newmem2:
  push r15
  mov r15,bPoliceRadar
  cmp byte ptr [r15],1
  pop r15
  je code2
  addss xmm0,[rdi+50]
code2:
  jmp return2

PoliceRadar:
  jmp newmem2
return2:

[DISABLE]

HeatLevel:
  db 44 8B 46 0C 45 85 C0

unregistersymbol(HeatLevel)
dealloc(newmem)

PoliceRadar:
  db F3 0F 58 47 50

unregistersymbol(PoliceRadar)
dealloc(newmem)

