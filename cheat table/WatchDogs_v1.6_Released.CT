        <CheatEntry>
          <ID>90432</ID>
          <Description>"God Mode"</Description>
          <Options moHideChildren="1" moDeactivateChildrenAsWell="1"/>
          <LastState/>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>{ Game   : Watch_Dogs.exe
  Version: 
  Date   : 2023-01-11
  Author : Paul44

  Will not die, even when falling from great heights...
  note: accesses list of enemies !
}

[ENABLE]
// system Godmode flag: check parent struct @ +40 (byte)
// google: [ Watch Dogs s0beit Other MMORPG and Strategy Disrupt_b64_dump_import ]

// R14 = main_struct entity (player, npc, enemy)
aobscanmodule(HealthGod,Disrupt_b64.dll,F3 0F 10 41 1C 0F 2F C8 72)
registersymbol(HealthGod)
alloc(newmem,$100,HealthGod)

aobscanmodule(Reputation,Disrupt_b64.dll,48 8D 4D 30 03 FB)
registersymbol(Reputation)
alloc(newmem2,$100,Reputation)

globalalloc(bGodNPC,1,HealthGod)
globalalloc(bReputation,1,Reputation)

bGodNPC:
db 1

bReputation:
db 0

label(code)
label(end)
label(return)
label(NPC)
label(Enemy)

newmem:
  movss xmm0,[rcx+1C]
  comiss xmm1,xmm0
code:
  push r15
  // always update reputation...
  mov r15,bReputation
  mov byte ptr [r15],0
  // check if player...
  mov r15,pHealth
  mov r15,[r15]
  // cmp sets CF=0
  cmp r15,rcx
  je end
  mov r15,bGodNPC
  cmp byte ptr [r15],1
  je NPC
Enemy:
  mov r15d,#10
  // cmp sets CF=1
  cmp r15d,#20
  jmp end
NPC:
  // npc_health = 10
  cmp dword ptr [rcx+1C],41A00000
  jne Enemy
  mov r15,bReputation
  mov byte ptr [r15],1
end:
  pop r15
  jmp return

HealthGod:
  jmp newmem
  nop 3
return:

// disable reputation when hitting npcs...
label(code2)
label(return2)

newmem2:
  // see Godmode...
  push r15
  mov r15,bReputation
  cmp byte ptr [r15],1
  jne code2
  mov edi,0
  mov byte ptr [r15],0
code2:
  pop r15
@@:
  lea rcx,[rbp+30]
  add edi,ebx
  jmp return2

Reputation:
  jmp newmem2
  nop
return2:


[DISABLE]

HealthGod:
  db F3 0F 10 41 1C 0F 2F C8

unregistersymbol(HealthGod)
dealloc(newmem)

Reputation:
  db 48 8D 4D 30 03 FB

unregistersymbol(Reputation)
dealloc(newmem2)

